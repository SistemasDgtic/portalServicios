<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">
<log4j:configuration debug="null">
    <appender name="SystemOut" class="org.apache.log4j.ConsoleAppender">
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern"
                               value="%d{ABSOLUTE} %5.5p %70.40c - %m%n"/>
        </layout>
    </appender>    
    <appender name="Roller" class="org.apache.log4j.RollingFileAppender">
        <param name="File" value="${dir.log}/sep-portal.log"/>
        <param name="MaxFileSize" value="5000KB"/>
        <param name="MaxBackupIndex" value="10"/>
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern" value="%d{ABSOLUTE} %5.5p %70.40c - %m%n" />
        </layout>
    </appender>
    <appender name="ASYNC" class="org.apache.log4j.AsyncAppender">
        <param name="Blocking" value="false"/>
        <param name="BufferSize" value="10480"/>
        <appender-ref ref="Roller"/>
        <appender-ref ref="SystemOut"/>
        <appender-ref ref="ErrorEmailAppender"/>
    </appender>
	
    <logger name="org.springframework.web">
        <level value="${modo.log.libs}"/>
    </logger>
    <logger name="org.springframework.web.servlet">
        <level value="${modo.log.libs}"/>
    </logger>
    <logger name="org.springframework.security">
        <level value="${modo.log.libs}"/>
    </logger>
    <logger name="org.springframework.security.access">
        <level value="${modo.log.libs}"/>
    </logger>
    <logger name="org.springframework.security.web">
        <level value="${modo.log.libs}"/>
    </logger>
    <logger name="org.springframework.security.core">
        <level value="${modo.log.libs}"/>
    </logger>
    <logger name="org.springframework.security.config">
        <level value="${modo.log.libs}"/>
    </logger>
    <logger name="mx.sep.expedicion.web">
        <level value="${modo.log}"/>
    </logger>

    <root>
        <priority value ="${modo.log}"/>
        <appender-ref ref="ASYNC"/>
    </root>
	
    <appender name="ErrorEmailAppender" class="org.apache.log4j.net.SMTPAppender">
        <param name="SMTPHost" value="smtp.office365.com" />
        <param name="SMTPPort" value="587" />
        <param name="SMTPUsername" value="portal.servicios@nube.sep.gob.mx" />
        <param name="SMTPPassword" value="Fay99117" />
        <param name="From" value="portal.servicios@nube.sep.gob.mx" />
        <param name="To" value="aarvizu@nube.sep.gob.mx" />
        <param name="Subject" value="Log4J Message error Portal de Auto Servicios ${up.log}" />
        <param name="BufferSize" value="1" />
        <param name="Threshold" value="error"/>
        <param name="EvaluatorClass" value="TriggerLogEvent" />
        <layout class="org.apache.log4j.PatternLayout">
            <param name="ConversionPattern" value="[%x] - %p - %d - %F - %m%n"/>
        </layout>
    </appender>
</log4j:configuration>