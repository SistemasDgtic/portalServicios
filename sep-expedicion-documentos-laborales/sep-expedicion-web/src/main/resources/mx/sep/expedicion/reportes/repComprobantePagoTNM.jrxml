	<parameter name="PATH_WEB" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Users/lucia martinez rosal/Documents/NetBeansProjects/sep-expedicion-documentos-laborales/sep-expedicion-web/src/main/webapp/"]]></defaultValueExpression>
	</parameter>
	<parameter name="pIdComprobante" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="PATH_JASPER" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:/Users/lucia martinez rosal/Documents/NetBeansProjects/sep-expedicion-documentos-laborales/sep-expedicion-web/src/main/resources/"]]></defaultValueExpression>
	</parameter>
	<parameter name="pCompTimExist" class="java.lang.Integer"/>
	<parameter name="pRfc" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
    comp.id_comprobante,
    TRIM(comp.nombre) as nombre,
    TRIM(tps001_tipo_nomina.descripcion) AS filiacion,
    comp.cve_unica,
    comp.rfc,
    comp.clave_presupuestal,
    comp.fecha_pago,
    comp.fecha_ini,
    comp.fecha_fin,
    comp.tot_perc_cheque,
    comp.tot_ded_cheque,
    comp.tot_neto_cheque,
    comp.numero_ss as nu_seg_soc,
    comp.clabe_inter,
    comp.centro_trabajo,
    TRIM(NVL(comp.mensaje_impresion,'')) as mensaje_impresion1,
    TRIM(comp.codigo_seguridad) as cod_seguridad,
    comp.num_comprobante,
    tsat.sello_dig_sep as sello_emisor,
    tsat.sello_dig_sat as sello_sat,
    tsat.num_certificado as certificado_sat,
    tsat.uuid
FROM tps003_comprobante comp,
    tps001_tipo_nomina,
    outer(tps013_timbra_sat tsat)
WHERE
    (
        comp.id_tipo_nomina = tps001_tipo_nomina.id_tipo_nomina
        and comp.id_comprobante = tsat.id_comprobante
    )
AND comp.id_comprobante = $P{pIdComprobante}
$P!{pRfc}]]>
	</queryString>
