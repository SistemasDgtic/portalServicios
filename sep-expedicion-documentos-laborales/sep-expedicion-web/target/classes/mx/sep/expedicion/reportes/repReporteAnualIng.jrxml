	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="pRfc" class="java.lang.String"/>
	<parameter name="pAnio" class="java.lang.Integer"/>
	<parameter name="PATH_WEB" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
a.rfc as rfc,
b.nombre_usuario as nombre,
a.tot_imp as  ing_anual_sueldo
FROM
     tps022_anual_sdo a, tps005_usuarios b
WHERE
    a.rfc =  $P{pRfc}
   AND a.anio =  $P{pAnio}
   AND a.rfc = b.username]]>
	</queryString>
	<field name="rfc" class="java.lang.String"/>
	<field name="nombre" class="java.lang.String"/>
	<field name="ing_anual_sueldo" class="java.math.BigDecimal"/>
