			<textField>
				<reportElement uuid="a2a18d05-2f1b-4245-a0c4-dbfa265b1e6b" x="7" y="588" width="558" height="20"/>
				<textElement textAlignment="Justified">
					<font size="5"/>
				</textElement>
				<textFieldExpression><![CDATA["SE DECLARA BAJO PROTESTA DE DECIR VERDAD, QUE LOS DATOS ASENTADOS EN LA PRESENTE CONSTANCIA, FUERON MANIFESTADOS EN LA RESPECTIVA DECLARACIÓN INFORMATIVA (MÚLTIPLE) DEL EJERCICIO, PRESENTADA ANTE EL SAT CON FECHA "+$F{fecha_presentacion}+" Y A LA QUE LE CORRESPONDIÓ EL NÚMERO DE FOLIO O DE OPERACIÓN "+ $F{num_folio} +", ASÍ MISMO, SI("+($F{calculo}.equals("S")?"X":" ")+") O NO ("+($F{calculo}.equals("N")?"X":" ")+") SE REALIZÓ EL CÁLCULO ANUAL EN LOS TÉRMINOS QUE ESTABLECE LA LEY DEL ISR."]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement uuid="a6f6519a-c087-4cee-aafc-b222e440b874" key="staticText-96" x="389" y="610" width="180" height="72"/>
