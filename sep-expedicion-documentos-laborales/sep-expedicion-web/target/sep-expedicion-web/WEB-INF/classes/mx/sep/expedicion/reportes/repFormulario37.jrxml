	<queryString>
		<![CDATA[select a.anio, a.rfc, a.cve_unica, a.nom_emp, a.ent_fed, a.area_geografica, a.qna_ini, a.qna_fin,
a.imp_sub,
 case when a.calculo  = 'S' then
            a.isr_anual
      else
            0.0
      end isr_anual,
a.sub_no_acre, a.sub_acre, a.total_cs, a.saldo_det, a.cred_sal, a.tot_imp, a.calculo, a.tipo_contrato,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 1),0) as cve1,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 2),0) as cve2,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 3),0) as cve3,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 4),0) as cve4,
nvl((select imp_exento from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 4),0) as exe4,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 5),0) as cve5,
nvl((select imp_exento from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 5),0) as exe5,
