nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 30),0) as cve30,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 31),0) as cve31,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 32),0) as cve32,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 33),0) as cve33,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 34),0) as cve34,
nvl((select imp_total from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 35),0) as cve35,
nvl((select imp_exento from tps016_detalle_isr where id_constancia = a.id_constancia and clave = 35),0) as exe35,
b.num_folio, b.fecha_presentacion
from tps015_isr_anual a, tps018_datos_dim b
where a.id_constancia = $P{pIdConstancia}
  and a.anio = b.anio]]>
