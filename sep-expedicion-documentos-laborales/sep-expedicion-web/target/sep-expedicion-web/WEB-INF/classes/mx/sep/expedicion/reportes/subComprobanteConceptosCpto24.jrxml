<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="subComprobanteConceptos" pageWidth="286" pageHeight="752" columnWidth="286" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="e2949c1c-16b7-407e-8946-07afcd4d794d">
	<property name="ireport.zoom" value="1.6105100000000008"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="pIdComprobante" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[new Integer("1")]]></defaultValueExpression>
	</parameter>
	<parameter name="pTpoConcepto" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["D"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT limit 21 TRIM(cc.descripcion) AS desc_concepto,
    CASE
        WHEN dc.perc_ded = 'P' AND dc.concepto = '24'
            THEN (dc.importe - sps007_importe_aguinaldo(dc.id_comprobante))
        ELSE dc.importe
        END AS im_concepto,
    dc.concepto as cve_concepto
FROM tps004_det_comprob dc,
    tps002_cat_concept cc
WHERE
    (
        dc.perc_ded = cc.perc_ded
    AND dc.concepto = cc.concepto
    AND dc.concepto in ('24','62')
    )
AND dc.id_comprobante = $P{pIdComprobante}
AND dc.perc_ded = '$P!{pTpoConcepto}']]>
	</queryString>
	<field name="desc_concepto" class="java.lang.String"/>
	<field name="im_concepto" class="java.math.BigDecimal"/>
	<field name="cve_concepto" class="java.lang.String"/>
	<detail>
		<band height="10">
			<textField>
				<reportElement uuid="3def0480-41cf-4037-9d2d-a1e10f6feb2e" mode="Transparent" x="0" y="0" width="33" height="10" backcolor="#E6FFE6"/>
				<box leftPadding="1" rightPadding="1">
					<topPen lineWidth="0.0"/>
					<leftPen lineWidth="0.0"/>
					<bottomPen lineWidth="0.0"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="7"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cve_concepto}.trim()]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement uuid="c1442ba9-81cd-407f-8b32-bb3f23b93e5c" mode="Transparent" x="33" y="0" width="198" height="10" backcolor="#E6FFE6"/>
				<box leftPadding="1" rightPadding="3">
					<topPen lineWidth="0.0"/>
					<leftPen lineWidth="0.0"/>
					<bottomPen lineWidth="0.0"/>
				</box>
				<textElement verticalAlignment="Middle">
					<font size="7"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{desc_concepto}.trim()]]></textFieldExpression>
			</textField>
			<textField pattern="#,##0.00;-#,##0.00">
				<reportElement uuid="f00afa05-1469-4ba0-adda-236b72404236" mode="Transparent" x="231" y="0" width="55" height="10" backcolor="#E6FFE6"/>
				<box leftPadding="1" rightPadding="3">
					<topPen lineWidth="0.0"/>
					<leftPen lineWidth="0.0"/>
					<bottomPen lineWidth="0.0"/>
				</box>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="7"/>
