                <property name="driverClassName" value="com.informix.jdbc.IfxDriver" />
                <property name="url" value="jdbc:informix-sqli://168.255.101.7:1540/portal_sector:informixserver=srvpsofm_tcp" />
                <property name="username" value="a713ap00" />
                <property name="password" value="aal7704" />
                <property name="initialSize" value="2" />
                <property name="maxActive" value="5" />
            </bean>        
        </beans>    
    -->	
  
    <beans profile="testing">
        <bean id="dataSource" class="org.springframework.jndi.JndiObjectFactoryBean">
            <property name="jndiName" value="jdbc/portal"/>
        </bean>
    </beans>		
	
    <!-- Podemos agregar otros profiles si requerimos de otros ambientes aplicativos. -->
    <beans profile="produccion-sc, produccion-sems, produccion-afsedf, produccion-tnm, produccion-cnbbbj">
        <bean id="dataSource" class="org.springframework.jndi.JndiObjectFactoryBean">
            <property name="jndiName" value="jdbc/portal"/>
        </bean>
    </beans>
    
</beans>
